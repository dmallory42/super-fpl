{
    "name": "superfpl/api",
    "description": "SuperFPL API Backend",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "SuperFPL\\Api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SuperFPL\\Api\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../packages/fpl-client"
        },
        {
            "type": "vcs",
            "url": "https://github.com/dmallory42/maia.git"
        }
    ],
    "require": {
        "php": ">=8.2",
        "superfpl/fpl-client": "^0.1",
        "predis/predis": "^2.3",
        "maia/framework": "^0.2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^4.0"
    }
}

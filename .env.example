# Core app mode
SUPERFPL_APP_ENV=development
SUPERFPL_DEBUG=1

# CORS origins (comma-separated)
# Dev example:  http://localhost:5173
# Prod example: https://superfpl.com,https://www.superfpl.com
SUPERFPL_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Required for admin-protected endpoints
SUPERFPL_ADMIN_TOKEN=replace_with_long_random_token

# API runtime paths
SUPERFPL_DB_PATH=/var/www/html/api/data/superfpl.db
SUPERFPL_CACHE_PATH=/var/www/html/api/cache
SUPERFPL_RATE_LIMIT_DIR=/var/www/html/api/cache/rate-limit
SUPERFPL_ERROR_LOG=/var/www/html/api/cache/logs/api-error.log

# Upstream FPL HTTP timeouts (seconds)
SUPERFPL_FPL_CONNECT_TIMEOUT=8
SUPERFPL_FPL_REQUEST_TIMEOUT=15

# Redis response cache
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379

# External APIs
ODDS_API_KEY=

# Caddy/deploy domain settings
DOMAIN=superfpl.com
WWW_DOMAIN=www.superfpl.com
TLS_EMAIL=ops@superfpl.com

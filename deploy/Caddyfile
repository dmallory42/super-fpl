{
	email {$TLS_EMAIL:ops@superfpl.com}
	servers {
		trusted_proxies static private_ranges
	}
}

{$DOMAIN:superfpl.com}, {$WWW_DOMAIN:www.superfpl.com} {
	encode zstd gzip

	@api path /api*
	handle @api {
		request_body {
			max_size 2MB
		}
		uri strip_prefix /api
		root * /var/www/html/api/public
		php_fastcgi php:9000 {
			env SUPERFPL_CORS_ALLOWED_ORIGINS "{$SUPERFPL_CORS_ALLOWED_ORIGINS:https://superfpl.com,https://www.superfpl.com}"
		}
		file_server
	}

	handle {
		root * /srv/frontend
		try_files {path} /index.html
		file_server
	}

	header /index.html Cache-Control "no-store"
	header /assets/* Cache-Control "public, max-age=31536000, immutable"
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self'; img-src 'self' data:;"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "geolocation=(), camera=(), microphone=()"
		-Server
	}

	log {
		output stdout
		format console
	}
}

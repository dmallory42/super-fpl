# Domain / TLS
DOMAIN=superfpl.com
WWW_DOMAIN=www.superfpl.com
TLS_EMAIL=ops@superfpl.com

# App runtime
SUPERFPL_APP_ENV=production
SUPERFPL_DEBUG=0
SUPERFPL_CORS_ALLOWED_ORIGINS=https://superfpl.com,https://www.superfpl.com

# Optional: if set, required for sync/admin/mutation endpoints
SUPERFPL_ADMIN_TOKEN=replace_with_long_random_token

# External APIs
ODDS_API_KEY=replace_me

# Redis (if REDIS_PASSWORD is set, include it in REDIS_URL too)
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# Runtime paths
SUPERFPL_DB_PATH=/var/www/html/api/data/superfpl.db
SUPERFPL_CACHE_PATH=/var/www/html/api/cache
SUPERFPL_RATE_LIMIT_DIR=/var/www/html/api/cache/rate-limit
SUPERFPL_ERROR_LOG=/var/www/html/api/cache/logs/api-error.log
